generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  service   String
  location  String?
  duration  String?
  message   String
  createdAt DateTime @default(now())
}

model Newsletter {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String
  company   String?
  service   String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}
